# Security headers — Cloudflare Pages / Netlify syntax.
/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  X-Frame-Options: SAMEORIGIN

# Long-cache the build-fingerprinted asset folder.
/_assets/*
  Cache-Control: public, max-age=31536000, immutable

# Long-cache woff2 fonts (names are stable; rotate with hash if needed).
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Cache video assets aggressively (they almost never change).
/videos/*
  Cache-Control: public, max-age=604800

# Brand images may be replaced; week-long cache is enough.
/images/*
  Cache-Control: public, max-age=604800
