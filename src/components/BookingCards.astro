---
import { Image } from 'astro:assets';
import { beachPositions } from '@data/prices';
import { phones } from '@data/contacts';
import imgSunbed from '@assets/images/beach-zone-umbrella.jpg';
import imgCanopy from '@assets/images/beach-zone-naves.jpg';
import imgPergola from '@assets/images/beach-zone-pergola.jpg';
import imgLounge from '@assets/images/beach-zone-star.jpg';

const beach = phones.find((p) => p.id === 'beach')!;
const imageById: Record<string, ImageMetadata> = {
  'sunbed-umbrella': imgSunbed,
  'sunbed-canopy': imgCanopy,
  pergola: imgPergola,
  'lounge-star': imgLounge,
};
---
<div class="grid gap-4 sm:gap-6 sm:grid-cols-2 xl:grid-cols-4">
  {beachPositions.map((p) => (
    <article class="card group flex flex-col">
      <div class="relative aspect-[16/10] sm:aspect-[4/3] overflow-hidden">
        <Image
          src={imageById[p.id]}
          alt={p.title}
          widths={[420, 640, 800]}
          sizes="(min-width: 1280px) 280px, (min-width: 640px) 45vw, 100vw"
          class="h-full w-full object-cover transition group-hover:scale-[1.03] duration-700"
          loading="lazy"
        />
        <span class="absolute top-3 left-3 inline-flex items-center rounded-full bg-white/95 px-3 py-1 text-xs font-medium text-teal-700 shadow-sm">
          Зона {p.zoneCode}
        </span>
        <span class="absolute top-3 right-3 inline-flex items-center rounded-full bg-coral-500 text-white px-3 py-1 text-xs font-medium shadow-sm sm:hidden">
          {p.fromPriceLabel}
        </span>
      </div>
      <div class="p-4 sm:p-5 flex-1 flex flex-col">
        <h3 class="font-display text-lg sm:text-xl text-ink">{p.title}</h3>
        {p.capacity && <p class="text-[11px] sm:text-xs uppercase tracking-wider2 text-coral-500 mt-1">{p.capacity}</p>}
        <p class="mt-2 text-sm text-ink-muted leading-relaxed">{p.shortDescription}</p>
        {p.includes && (
          <ul class="mt-3 space-y-1 text-sm text-ink-soft">
            {p.includes.slice(0, 3).map((i) => (
              <li class="flex items-start gap-2">
                <span class="mt-1.5 h-1.5 w-1.5 flex-none rounded-full bg-coral-500"></span>
                <span>{i}</span>
              </li>
            ))}
          </ul>
        )}
        <div class="mt-auto pt-4 sm:pt-5 flex items-end justify-between gap-3">
          <span class="font-medium text-teal-700 hidden sm:block">{p.fromPriceLabel}</span>
          <a href={beach.bookingUrl!} target="_blank" rel="noopener" class="btn-dark text-sm w-full sm:w-auto" data-analytics="click_book_beach">
            Забронювати
          </a>
        </div>
      </div>
    </article>
  ))}
</div>
