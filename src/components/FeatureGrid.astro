---
import { whyHere } from '@data/services';

interface Props {
  items?: typeof whyHere;
}
const { items = whyHere } = Astro.props;
---
<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
  {items.map((f) => (
    <div class="rounded-3xl bg-white p-6 shadow-card">
      <h3 class="font-display text-xl text-ink">{f.title}</h3>
      <p class="mt-2 text-sm text-ink-muted leading-relaxed">{f.text}</p>
    </div>
  ))}
</div>
