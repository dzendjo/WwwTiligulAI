---
import { faq } from '@data/faq';
interface Props { items?: typeof faq; }
const { items = faq } = Astro.props;
---
<div class="mx-auto max-w-3xl divide-y divide-sand-300/60 rounded-3xl bg-white shadow-card">
  {items.map((f, i) => (
    <details class="group p-5 sm:p-6" name="faq" open={i === 0}>
      <summary class="flex cursor-pointer list-none items-start justify-between gap-4">
        <span class="font-display text-lg text-ink">{f.q}</span>
        <span aria-hidden="true" class="mt-1 inline-flex h-7 w-7 flex-none items-center justify-center rounded-full bg-sand-200 text-teal-700 group-open:bg-coral-500 group-open:text-white transition">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" class="group-open:rotate-45 transition">
            <line x1="12" y1="6" x2="12" y2="18"/>
            <line x1="6" y1="12" x2="18" y2="12"/>
          </svg>
        </span>
      </summary>
      <p class="mt-3 text-ink-muted leading-relaxed [&_a]:text-coral-500 [&_a]:font-medium [&_a]:hover:underline [&_a]:underline-offset-2" set:html={f.a} />
    </details>
  ))}
</div>
