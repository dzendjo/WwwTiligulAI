---
// Inline SVG icons for social channels. currentColor — lets the parent control fill via text color.
interface Props {
  id: 'instagram' | 'facebook' | 'telegram' | 'youtube';
  /** Tailwind size class, default w-4 h-4. */
  class?: string;
}
const { id, class: className = 'w-4 h-4' } = Astro.props;
---
{id === 'instagram' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class={className} aria-hidden="true">
    <rect x="3" y="3" width="18" height="18" rx="5" />
    <circle cx="12" cy="12" r="4" />
    <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none" />
  </svg>
)}
{id === 'facebook' && (
  <svg viewBox="0 0 24 24" fill="currentColor" class={className} aria-hidden="true">
    <path d="M13.5 22v-8h2.7l.4-3.2h-3.1V8.7c0-.9.3-1.6 1.6-1.6h1.7V4.2c-.3 0-1.3-.1-2.4-.1-2.4 0-4 1.5-4 4.1v2.6H7.7V14h2.7v8h3.1z" />
  </svg>
)}
{id === 'telegram' && (
  <svg viewBox="0 0 24 24" fill="currentColor" class={className} aria-hidden="true">
    <path d="M21.7 3.4 2.6 10.8c-1.3.5-1.3 1.3-.2 1.6l4.9 1.5L18.5 7c.5-.3 1-.2.6.2L10 15.8l-.4 5c.5 0 .7-.2 1-.5l2.4-2.3 4.9 3.7c.9.5 1.6.3 1.8-.8l3.3-15.4c.3-1.4-.5-2-1.3-1.7z" />
  </svg>
)}
{id === 'youtube' && (
  <svg viewBox="0 0 24 24" fill="currentColor" class={className} aria-hidden="true">
    <path d="M21.6 7.2a2.5 2.5 0 0 0-1.8-1.8C18.2 5 12 5 12 5s-6.2 0-7.8.4A2.5 2.5 0 0 0 2.4 7.2C2 8.8 2 12 2 12s0 3.2.4 4.8a2.5 2.5 0 0 0 1.8 1.8C5.8 19 12 19 12 19s6.2 0 7.8-.4a2.5 2.5 0 0 0 1.8-1.8C22 15.2 22 12 22 12s0-3.2-.4-4.8zM10 15V9l5.2 3L10 15z" />
  </svg>
)}
