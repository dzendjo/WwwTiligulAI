---
interface Crumb { label: string; href?: string }
interface Props { items: Crumb[] }
const { items } = Astro.props;
---
<nav aria-label="Хлібні крихти" class="container-x mt-4 text-sm text-ink-muted">
  <ol class="flex flex-wrap items-center gap-2">
    {items.map((c, i) => (
      <li class="flex items-center gap-2">
        {c.href && i < items.length - 1 ? (
          <a href={c.href} class="hover:text-coral-500">{c.label}</a>
        ) : (
          <span aria-current="page" class="text-ink">{c.label}</span>
        )}
        {i < items.length - 1 && <span aria-hidden="true">/</span>}
      </li>
    ))}
  </ol>
</nav>
