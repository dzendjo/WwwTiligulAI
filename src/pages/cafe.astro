---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeader from '@components/SectionHeader.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { Image } from 'astro:assets';
import { phones } from '@data/contacts';
import { site } from '@data/site';

import cafeMain from '@assets/images/cafe-main.jpg';
import cafeSeafood from '@assets/images/cafe-seafood.jpg';
import cafeSoups from '@assets/images/cafe-soups.jpg';
import hut from '@assets/images/beach-02.jpg';
import porthole from '@assets/images/beach-04.jpg';
import safariFeast from '@assets/images/beach-08.jpg';

const beach = phones.find((p) => p.id === 'beach')!;

const breadcrumbJson = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Головна', item: site.url + '/' },
    { '@type': 'ListItem', position: 2, name: 'Кафе та бар', item: site.url + '/cafe' },
  ],
};

const restaurantJson = {
  '@context': 'https://schema.org',
  '@type': 'Restaurant',
  name: 'Tiligul Club Bar & Cafe',
  servesCuisine: ['Seafood', 'Grill', 'Mediterranean'],
  priceRange: '$$',
  url: site.url + '/cafe',
  telephone: beach.tel,
  address: {
    '@type': 'PostalAddress',
    addressLocality: site.address.locality,
    addressRegion: site.address.region,
    addressCountry: 'UA',
  },
};

const menu = [
  { group: 'Локальні морепродукти', items: ['Креветки на тарілці', 'Мідії в соусі', 'Восьминіг на грилі', 'Лиманські раки сезонні'] },
  { group: 'Гриль на вогні', items: ['Стейк рибний', 'Шашлик зі свинини', 'Гриль курка', 'Овочі на грилі'] },
  { group: 'Світла кухня', items: ['Піта з креветками', 'Севіче з лиманської риби', 'Грецький салат', 'Гаспачо'] },
  { group: 'Десерти', items: ['Сезонні фрукти', 'Чізкейк дня', 'Морозиво', 'Тістечка від кухні'] },
  { group: 'Бар і напої', items: ['Авторські коктейлі', 'Локальне вино', 'Лимонад на трав’яних настоях', 'Кава espresso bar'] },
];
---
<BaseLayout
  title="Кафе і бар Tiligul Club — локальні морепродукти, гриль, коктейлі"
  description="Пляжний бар і кафе на Тилігульському лимані: локальні морепродукти, гриль на справжньому вогні, сезонні десерти, авторські коктейлі та вино. Сервіс приходить до шезлонга."
  path="/cafe"
  ogImage="/images/og/cafe.jpg"
  jsonLd={[breadcrumbJson, restaurantJson]}
>
  <Breadcrumbs items={[{ label: 'Головна', href: '/' }, { label: 'Кафе та бар' }]} />

  <section class="section pt-10">
    <div class="container-x grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <span class="eyebrow">Кафе і бар</span>
        <h1 class="font-display text-4xl sm:text-5xl text-ink mt-3">Локальне, з гриля, біля води</h1>
        <p class="mt-5 text-ink-muted leading-relaxed">
          Морепродукти з лиману, м’ясо й риба з гриля на справжньому вогні,
          домашні десерти, авторські коктейлі та вино. Сервіс приносить замовлення
          до вашого шезлонга, перголи чи лаунж-зірки — за смачним нікуди йти.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href="https://expz.menu/8b91fb51-73fc-4b02-863c-59411f2914b8" target="_blank" rel="noopener" class="btn-primary">Меню</a>
        </div>
      </div>
      <!-- Mosaic: main portrait (row-span-2) + 2 landscape helpers stacked -->
      <div class="grid grid-cols-2 gap-3 sm:gap-4">
        <div class="row-span-2 rounded-3xl overflow-hidden">
          <Image src={cafeMain} alt="Стіл із локальними закусками й вином над водою Тилігульського лиману" widths={[400, 640, 800]} sizes="(min-width: 1024px) 300px, 45vw" class="h-full w-full object-cover" loading="eager" fetchpriority="high" />
        </div>
        <div class="rounded-3xl overflow-hidden aspect-[4/3]">
          <Image src={cafeSeafood} alt="Тарілка з локальних смажених морепродуктів біля води" widths={[300, 480, 640]} sizes="(min-width: 1024px) 300px, 45vw" class="h-full w-full object-cover" loading="lazy" />
        </div>
        <div class="rounded-3xl overflow-hidden aspect-[4/3]">
          <Image src={cafeSoups} alt="Сезонні супи на терасі кафе" widths={[300, 480, 640]} sizes="(min-width: 1024px) 300px, 45vw" class="h-full w-full object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section id="menu" class="section">
    <div class="container-x">
      <SectionHeader eyebrow="Меню" title="Що зазвичай у меню" intro="Сезонне меню змінюється з продуктами місяця. Нижче — постійні позиції; найсвіжіший список — в Instagram." />
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {menu.map((m) => (
          <div class="rounded-3xl bg-white shadow-card p-6">
            <h3 class="font-display text-xl text-ink">{m.group}</h3>
            <ul class="mt-3 space-y-2 text-ink-soft">
              {m.items.map((i) => (
                <li class="flex gap-2"><span class="text-coral-500 mt-1">•</span><span>{i}</span></li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-x">
      <SectionHeader eyebrow="Атмосфера" title="Бар, тераса і вечірні гости" />
      <div class="grid grid-cols-2 lg:grid-cols-3 gap-3">
        <Image src={hut} alt="Інтер’єр бару з муралом" widths={[400, 720]} sizes="(min-width: 1024px) 380px, 45vw" class="rounded-3xl aspect-[4/5] object-cover w-full h-full" loading="lazy" />
        <Image src={porthole} alt="Вид із бару на пляж крізь декоративне вікно" widths={[400, 720]} sizes="(min-width: 1024px) 380px, 45vw" class="rounded-3xl aspect-[4/5] object-cover w-full h-full" loading="lazy" />
        <Image src={safariFeast} alt="Сервіс у глемпі Safari — гриль і вино" widths={[400, 720]} sizes="(min-width: 1024px) 380px, 45vw" class="rounded-3xl aspect-[4/5] object-cover w-full h-full" loading="lazy" />
      </div>
    </div>
  </section>
</BaseLayout>
