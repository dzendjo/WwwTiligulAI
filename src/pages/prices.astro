---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeader from '@components/SectionHeader.astro';
import PriceTable from '@components/PriceTable.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { glampingTypes, kiteServices, priceNotes } from '@data/prices';
import { phones } from '@data/contacts';
import { site } from '@data/site';

const beach = phones.find((p) => p.id === 'beach')!;
const glampPhone = phones.find((p) => p.id === 'glamping')!;
const kitePhone = phones.find((p) => p.id === 'kite')!;

const breadcrumbJson = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Головна', item: site.url + '/' },
    { '@type': 'ListItem', position: 2, name: 'Ціни', item: site.url + '/prices' },
  ],
};
---
<BaseLayout
  title="Ціни Tiligul Club — пляж, глемпінг, кайт-школа, прокат"
  description="Прозорі ціни на шезлонги, перголи, павільйон-зірки, глемпи Junior / Safari / Comet та послуги кайт-школи. Розбивка по сезонах і днях тижня."
  path="/prices"
  ogImage="/images/og/prices.jpg"
  jsonLd={[breadcrumbJson]}
>
  <Breadcrumbs items={[{ label: 'Головна', href: '/' }, { label: 'Ціни' }]} />

  <!-- Intro -->
  <section class="container-x pt-6 pb-4 sm:pt-10 sm:pb-6">
    <SectionHeader
      eyebrow="Ціни"
      title="Все, що варто бронювати — в одному місці"
      intro="Базові ціни сезону. Точні умови щодо знижок і доплат — підтверджує адміністратор при бронюванні."
      as="h1"
    />
  </section>

  <!-- Beach -->
  <section class="container-x pb-10 sm:pb-14">
    <h2 class="font-display text-2xl text-ink mb-4">Пляж</h2>
    <PriceTable />
    <div class="mt-5 sm:mt-6">
      <a href={beach.bookingUrl!} target="_blank" rel="noopener" class="btn-primary" data-analytics="click_book_beach">
        Забронювати пляж онлайн
      </a>
    </div>
  </section>

  <!-- Glamping -->
  <section class="py-10 sm:py-14">
    <div class="container-x">
      <h2 class="font-display text-2xl text-ink mb-4">Глемпінг</h2>
      <div class="overflow-x-auto -mx-4 sm:mx-0">
        <table class="price-table min-w-[640px] sm:min-w-full">
          <thead>
            <tr>
              <th class="!rounded-tl-2xl">Тип</th>
              <th>Площа</th>
              <th>Гостей</th>
              <th class="!rounded-tr-2xl text-right">Ціна від</th>
            </tr>
          </thead>
          <tbody class="bg-white">
            {glampingTypes.map((g) => (
              <tr>
                <td><span class="font-medium text-ink">{g.title}</span></td>
                <td>{g.size}</td>
                <td>{g.guests}</td>
                <td class="text-right font-medium text-teal-700">{g.fromPriceLabel}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="mt-5 sm:mt-6">
        <a href={glampPhone.bookingUrl!} target="_blank" rel="noopener" class="btn-primary" data-analytics="click_book_glamping">
          Забронювати глемп онлайн
        </a>
      </div>
    </div>
  </section>

  <!-- Kite -->
  <section class="py-10 sm:py-14 bg-white">
    <div class="container-x">
      <h2 class="font-display text-2xl text-ink mb-4">Кайт-школа</h2>
      <div class="grid sm:grid-cols-2 gap-3 sm:gap-4">
        {kiteServices.map((k) => (
          <div class="rounded-3xl bg-sand-100 shadow-card p-5 flex flex-col">
            <h3 class="font-display text-xl text-ink">{k.title}</h3>
            <p class="mt-2 text-sm text-ink-muted leading-relaxed">{k.description}</p>
            {k.fromPriceLabel && <p class="mt-3 font-medium text-teal-700">{k.fromPriceLabel}</p>}
          </div>
        ))}
      </div>
      <div class="mt-5 sm:mt-6">
        <a href={kitePhone.telegram!} target="_blank" rel="noopener" class="btn-primary" data-analytics="click_kite_contact">
          Написати в Telegram
        </a>
      </div>
    </div>
  </section>

  <!-- Notes -->
  <section class="py-10 sm:py-14">
    <div class="container-x max-w-3xl">
      <SectionHeader eyebrow="Важливо" title="Кілька приміток до цін" />
      <ul class="space-y-2.5 text-ink-muted mt-2">
        {priceNotes.map((n) => (
          <li class="flex gap-3"><span class="text-coral-500 flex-none">•</span><span>{n}</span></li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
