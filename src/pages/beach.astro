---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHeader from '@components/SectionHeader.astro';
import BookingCards from '@components/BookingCards.astro';
import BeachZoneMap from '@components/BeachZoneMap.astro';
import PhotoGrid from '@components/PhotoGrid.astro';
import FAQAccordion from '@components/FAQAccordion.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import { Image } from 'astro:assets';
import { phones } from '@data/contacts';
import { site } from '@data/site';
import { faq } from '@data/faq';
// FAQ items relevant to beach visitors: booking, wristbands, safety, showers, walk-ins, weather.
const beachFaq = [0, 1, 2, 3, 9, 10].map((i) => faq[i]).filter(Boolean);
import beachHero from '@assets/images/beach-04.jpg';
import beachLounge from '@assets/images/beach-07.jpg';
import beachHut from '@assets/images/beach-02.jpg';
import beachBeans from '@assets/images/beach-05.jpg';

const beach = phones.find((p) => p.id === 'beach')!;

const breadcrumbJson = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Головна', item: site.url + '/' },
    { '@type': 'ListItem', position: 2, name: 'Пляж', item: site.url + '/beach' },
  ],
};

const stripHtml = (html: string) => html.replace(/<[^>]+>/g, '').replace(/&nbsp;/g, ' ').replace(/\s+/g, ' ').trim();
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: beachFaq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: stripHtml(f.a) },
  })),
};
---
<BaseLayout
  title="Пляж Tiligul Club — шезлонги, перголи, лаунж-зірки на Тилігульському лимані"
  description="Шезлонги під навісом, шезлонги з парасолею, перголи на компанію, лаунж-зірки до 6 осіб. Душі, туалети, опріснювальна зона, бар і кафе на пляжі."
  path="/beach"
  ogImage="/images/og/beach.jpg"
  jsonLd={[breadcrumbJson, faqJsonLd]}
>
  <Breadcrumbs items={[{ label: 'Головна', href: '/' }, { label: 'Пляж' }]} />

  <section class="section pt-10">
    <div class="container-x grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <span class="eyebrow">Пляж</span>
        <h1 class="font-display text-4xl sm:text-5xl text-ink mt-3">Шезлонги, перголи і лаунж-зірки на косі лиману</h1>
        <p class="mt-5 text-ink-muted leading-relaxed">
          Пляжний майданчик Tiligul Club — це чотири типи позицій від простого шезлонга до
          лаунж-зірки на велику компанію, плюс усе необхідне для дня на воді: душі, туалети,
          бар, опріснювальна зона і браслети доступу.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href={`tel:${beach.tel}`} class="btn-primary" data-analytics="click_book_beach">Забронювати: {beach.display}</a>
          <a href="/prices" class="btn-secondary">Ціни</a>
        </div>
      </div>
      <Image src={beachHero} alt="Вид із пляжного бару на купальників у воді Тилігульського лиману" widths={[640, 960, 1280]} sizes="(min-width: 1024px) 560px, 90vw" class="rounded-[2rem] aspect-[4/5] object-cover w-full h-full shadow-card" loading="eager" fetchpriority="high" />
    </div>
  </section>

  <section class="section">
    <div class="container-x">
      <SectionHeader eyebrow="Бронювання" title="Чотири типи пляжних позицій" />
      <BookingCards />
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-x">
      <SectionHeader eyebrow="Схема" title="Як організований пляж" intro="Зони U, L, R, P та S — простіша орієнтація і швидке бронювання." />
      <BeachZoneMap />
    </div>
  </section>

  <section class="section">
    <div class="container-x">
      <SectionHeader eyebrow="Атмосфера" title="Як виглядає звичайний день" />
      <PhotoGrid
        items={[
          { src: beachLounge, alt: 'Гостя на лаунжі біля води' },
          { src: beachHut, alt: 'Пляжний бар із муралом' },
          { src: beachBeans, alt: 'Кольорові безкаркасні крісла на піску' },
          { src: beachHero, alt: 'Вид крізь декоративне вікно бару на пляж' },
        ]}
      />
    </div>
  </section>

  <section class="section bg-sand-200/40">
    <div class="container-x max-w-3xl">
      <SectionHeader eyebrow="Що входить у бронювання" title="Деталі, які зазвичай запитують" />
      <ul class="grid sm:grid-cols-2 gap-3 text-ink-soft">
        {[
          'Браслет доступу до пляжу на дорослого гостя',
          'Шезлонг із матрацом або пергола з тінню',
          'Доступ до душів і туалетів',
          'Опріснювальна зона після купання',
          'Сервіс із пляжного бару до місця',
          'Безкоштовне користування дітьми до 7 років (у супроводі)',
        ].map((b) => (
          <li class="flex items-start gap-3 rounded-2xl bg-white shadow-card p-4">
            <span class="mt-1 h-2 w-2 flex-none rounded-full bg-coral-500"/>
            <span>{b}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="container-x">
      <SectionHeader eyebrow="FAQ" title="Питання про пляж" center />
      <FAQAccordion items={beachFaq} />
    </div>
  </section>
</BaseLayout>
